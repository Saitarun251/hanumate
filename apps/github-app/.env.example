# Environment Variables for RubberDuck GitHub App

# Required: GitHub App credentials
GITHUB_APP_ID=your_app_id_here
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_content_here\n-----END RSA PRIVATE KEY-----"
WEBHOOK_SECRET=your_webhook_secret_here

# Optional: RubberDuck runtime
HANUMATE_API_URL=https://api.hanumate.dev
RUBBERDUCK_API_KEY=your_api_key_here

# Optional: Task configuration
TASK_TIMEOUT=300000

# Server configuration
PORT=3000
NODE_ENV=production