{
	"name": "@kishkindhalabs/hanumate-opentelemetry",
	"version": "0.1.0",
	"type": "module",
	"description": "OpenTelemetry setup helpers for RubberDuck",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check:types": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/sdk-trace-node": "^1.30.1",
		"@opentelemetry/sdk-trace-base": "^1.30.1",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/resources": "^1.30.1",
		"@opentelemetry/semantic-conventions": "^1.30.1"
	},
	"devDependencies": {
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"@kishkindhalabs/hanumate-runtime": "^0.1.0"
	}
}